#### Fix 2: Invalidate local cache on canvas clear

**Where:** `CanvasDrawingPage.tsx` — in the `canvas_cleared` event handler

**Find the existing handler and add the cache invalidation:**
```typescript
// In the handleClear / canvas_cleared event handler:
const handleClear = (message: any) => {
  const clearedPageId = message.page_id;
  const currentPageKey = isCoverImage ? 'cover_image' : (pageId || `page_${pageIndex}`);
  
  if (clearedPageId !== currentPageKey) return;
  
  // Clear Paper.js canvas in memory
  if (drawingEngineRef.current) {
    drawingEngineRef.current.clearCanvas();
  }

  // ✅ NEW: Also clear local storyStore cache so re-entry shows blank canvas
  if (storyId) {
    saveCanvasData(storyId, pageId!, null); // wipe the page data
    console.log('🗑️ Cleared local canvas cache for page:', pageId);
  }
};
```

